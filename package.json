{
  "name": "atleticageneve",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:api": "wrangler dev src/api/index.ts",
    "build:web": "tsc -b && vite build",
    "build:api": "wrangler deploy src/api/index.ts --dry-run",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply atletica-db --local",
    "db:seed": "wrangler d1 execute atletica-db --local --file=src/api/db/seed.sql",
    "deploy:api": "wrangler deploy src/api/index.ts",
    "build:web:prod": "VITE_API_URL=https://atletica-api.olivier-lemer.workers.dev vite build",
    "deploy:web": "npm run build:web:prod && wrangler pages deploy dist"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "@tanstack/react-query": "^5.80.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "i18next": "^25.1.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.5.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.1",
    "wrangler": "^4.14.0"
  }
}
